{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "description": {
      "type": ["string", "null"],
      "maxLength": 1000
    },
    "priority": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH"]
    },
    "status": {
      "type": "string",
      "enum": ["TODO", "IN_PROGRESS", "DONE"]
    },
    "dueDate": {
      "type": ["string", "null"],
      "format": "date"
    },
    "userId": {
      "type": "integer",
      "minimum": 1
    },
    "createdAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "updatedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "required": ["id", "title", "priority", "status", "userId", "createdAt", "updatedAt"],
  "additionalProperties": false
}
