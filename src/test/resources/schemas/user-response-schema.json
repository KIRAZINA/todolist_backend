{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1
    },
    "username": {
      "type": "string",
      "minLength": 3,
      "maxLength": 50
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "role": {
      "type": "string",
      "enum": ["USER", "ADMIN"]
    },
    "createdAt": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "required": ["id", "username", "email", "role"],
  "additionalProperties": false
}
